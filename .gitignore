# Удалить конфликтный файл
Remove-Item .gitignore -Force

# Создать новый .gitignore
@"
# Dependencies
node_modules/
package-lock.json

# Build output
dist/
build/

# Environment variables
.env
.env.local
.env.production
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Testing
coverage/
*.lcov

# Misc
.vercel
*.tsbuildinfo
.cache/
.npm/
"@ | Out-File -FilePath .gitignore -Encoding utf8